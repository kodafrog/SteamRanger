{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "steamranger",
  "version": "0.1.0",
  "identifier": "com.steamranger.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Steam Ranger, your Steam achievement guide",
        "width": 1200,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5MzQ5OTRERjUzMzE0M0EKUldRNkZEUDFUWmswV1pCbWw0d054WndWT1E3bE1oZmhLZG9ybTJ1UkJ4N0pQT3A0a0VaSVBBbjMK",
      "endpoints": [
        "https://github.com/JoshSims77/SteamRanger/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "steamranger",
  "version": "0.1.12",
  "identifier": "com.steamranger.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SteamRanger: ",
        "width": 1200,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "devtools": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3NjZENkRCQThDOTA3QkUKUldTK0I4bW8yOVptdDM4OVlQd25ZaEVENyszOG5mN3Y0LzNtdTdHaHc5dkV2RWoxYzZBVGRYQ3YK",
      "endpoints": [
        "https://github.com/JoshSims77/SteamRanger/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}